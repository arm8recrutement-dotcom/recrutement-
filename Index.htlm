<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ARM8 - Recrutement Complet</title>
    <style>
        :root {
            --container-bg: rgba(43, 45, 49, 0.9); /* Un poil plus opaque pour que le grand texte reste super lisible */
            --input-bg: #1e1f22;
            --accent-color: #5865F2;
            --accent-hover: #4752C4;
            --text-color: #f2f3f5;
            --text-muted: #b5bac1;
            --border-color: #3f4147;
        }

        body {
            font-family: 'GG Sans', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-image: url("https://cdn.discordapp.com/attachments/1490407191960879146/1525172419764027543/73B0B19D-DBB1-437B-B482-B1FAF8CCD409.png?ex=6a526b01&is=6a511981&hm=454a8c75c756900697f6267738bebccccc8511cd72ed15c2c5f678addefa7a97&");
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
            background-repeat: no-repeat;
            margin: 0;
            padding: 20px 10px;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            box-sizing: border-box;
        }

        .container {
            background-color: var(--container-bg);
            backdrop-filter: blur(5px);
            padding: 30px 25px;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.6);
            width: 100%;
            max-width: 550px; /* Légèrement plus large pour les longues questions */
            border: 1px solid var(--border-color);
        }

        .header {
            text-align: center;
            margin-bottom: 25px;
        }

        .discord-logo {
            width: 60px;
            height: 60px;
            background-color: var(--accent-color);
            border-radius: 50%;
            display: inline-flex;
            justify-content: center;
            align-items: center;
            margin-bottom: 12px;
        }

        .discord-logo svg {
            width: 35px;
            height: 35px;
            fill: white;
        }

        h2 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
            color: var(--text-color);
            letter-spacing: 0.5px;
        }

        .subtitle {
            color: var(--text-muted);
            font-size: 14px;
            margin-top: 5px;
        }

        .form-group {
            margin-bottom: 22px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: var(--text-muted);
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            line-height: 1.4;
        }

        .label-desc {
            display: block;
            font-size: 11px;
            color: #949ba4;
            font-weight: normal;
            text-transform: none;
            margin-top: 2px;
            letter-spacing: 0;
        }

        input[type="text"], input[type="number"], select, textarea {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 4px;
            background-color: var(--input-bg);
            color: var(--text-color);
            box-sizing: border-box;
            font-size: 14px;
            outline: none;
            transition: box-shadow 0.2s;
        }

        input[type="text"]:focus, input[type="number"]:focus, select:focus, textarea:focus {
            box-shadow: 0 0 0 2px var(--accent-color);
        }

        select {
            cursor: pointer;
            appearance: none;
            background-image: url("data:image/svg+xml;utf8,<svg fill='white' height='24' viewBox='0 0 24 24' width='24' xmlns='http://www.w3.org/2000/svg'><path d='M7 10l5 5 5-5z'/><path d='M0 0h24v24H0z' fill='none'/></svg>");
            background-repeat: no-repeat;
            background-position: right 10px center;
            background-size: 20px;
        }

        textarea {
            resize: none;
            height: 95px;
            font-family: inherit;
        }

        .hidden {
            display: none !important;
        }

        .fade-in {
            animation: fadeIn 0.3s ease-in-out forwards;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-8px); }
            to { opacity: 1; transform: translateY(0); }
        }

        button {
            width: 100%;
            padding: 14px;
            background-color: var(--accent-color);
            border: none;
            border-radius: 4px;
            color: white;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 15px;
        }

        button:hover {
            background-color: var(--accent-hover);
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <div class="discord-logo">
            <svg viewBox="0 0 127.14 96.36">
                <path d="M107.7,8.07A105.15,105.15,0,0,0,77.26,0a77.19,77.19,0,0,0-3.3,6.83A96.67,96.67,0,0,0,53.22,6.83,77.19,77.19,0,0,0,49.88,0,105.15,105.15,0,0,0,19.44,8.07C3.66,31.58-1.86,54.65,1,77.53A105.73,105.73,0,0,0,32,96.36a74.37,74.37,0,0,0,6.7-10.93,68.43,68.43,0,0,1-10.59-5.07c.9-.66,1.77-1.35,2.6-2.07a75.31,75.31,0,0,0,72.7,0c.83.72,1.7,1.41,2.6,2.07a68.32,68.32,0,0,1-10.59,5.07,74.68,74.68,0,0,0,6.7,10.93,105.54,105.54,0,0,0,31.05-18.83C129.91,50.14,124.06,27.24,107.7,8.07ZM42.45,65.69C36.18,65.69,31,60,31,53S36.18,40.36,42.45,40.36,53.92,46,53.79,53,48.72,65.69,42.45,65.69Zm42.24,0C78.41,65.69,73.24,60,73.24,53S78.41,40.36,82.69,40.36,94.16,46,94,53,89,65.69,82.69,65.69Z"/>
            </svg>
        </div>
        <h2>ARM8 RECRUTEMENT</h2>
        <div class="subtitle">Formulaire officiel de candidature</div>
    </div>
    
    <form id="recrutementForm">
        
        <div class="form-group">
            <label for="pseudo">Pseudo Discord & ID Unique</label>
            <input type="text" id="pseudo" required placeholder="Ex: MonPseudo#0000 ou 123456789012345">
        </div>

        <div class="form-group">
            <label for="age">Quel est votre âge ?</label>
            <input type="number" id="age" required min="10" max="99" placeholder="Ex: 16">
        </div>

        <div class="form-group">
            <label for="dispo">Vos disponibilités de connexion <span class="label-desc">Indiquez vos horaires en semaine et le week-end</span></label>
            <textarea id="dispo" required placeholder="Ex: Lundi au vendredi de 17h à 22h, week-end toute la journée."></textarea>
        </div>

        <div class="form-group">
            <label for="poste">Quel poste souhaitez-tu occuper ?</label>
            <select id="poste" onchange="changerPoste()" required>
                <option value="" disabled selected>Choisis un rôle...</option>
                <option value="Staff">🛡️ Staff / Modérateur</option>
                <option value="Animateur">🎉 Animateur d'Événements</option>
                <option value="Middleman">🤝 Middleman Sécurisé</option>
            </select>
        </div>

        <div id="sectionStaff" class="hidden">
            <div class="form-group">
                <label for="xpStaff">Vos expériences dans la modération <span class="label-desc">Avez-vous déjà été staff sur d'autres serveurs Discord ?</span></label>
                <textarea id="xpStaff" placeholder="Détaillez vos anciennes expériences et les outils de modération que vous connaissez..."></textarea>
            </div>
            <div class="form-group">
                <label for="motivationStaff">Quelles sont vos motivations profondes ? <span class="label-desc">Pourquoi vous et pas un autre candidat ?</span></label>
                <textarea id="motivationStaff" placeholder="Expliquez ce que vous pouvez apporter de positif au serveur ARM8..."></textarea>
            </div>
            <div class="form-group">
                <label for="scenarioStaff">Mise en situation (Obligatoire) <span class="label-desc">Un membre commence à insulter gravement et à spammer dans le chat général alors qu'aucun admin n'est connecté. Que faites-vous précisément ?</span></label>
                <textarea id="scenarioStaff" placeholder="Décrivez toutes les étapes de votre réaction..."></textarea>
            </div>
        </div>

        <div id="sectionAnimateur" class="hidden">
            <div class="form-group">
                <label for="ideesAnim">Quelles idées d'événements originaux proposez-vous ? <span class="label-desc">Donnez au moins 2 exemples d'animations</span></label>
                <textarea id="ideesAnim" placeholder="Décrivez des animations vocales ou textuelles pour dynamiser le serveur..."></textarea>
            </div>
            <div class="form-group">
                <label for="xpAnim">Avez-vous de l'expérience dans l'animation ?</label>
                <textarea id="xpAnim" placeholder="Projets passés, serveurs animés ou outils de mini-jeux connus..."></textarea>
            </div>
        </div>

        <div id="sectionMiddleman" class="hidden">
            <div class="form-group">
                <label for="xpMm">Nombre de transactions sécurisées & Preuves <span class="label-desc">Décrivez votre passif en tant que tiers de confiance</span></label>
                <textarea id="xpMm" placeholder="Ex: Déjà 20 transactions réussies, liste de vouchers dispo..."></textarea>
            </div>
            <div class="form-group">
                <label for="scenarioMm">Mise en situation Middleman <span class="label-desc">Pendant un échange, l'un des deux joueurs tente de vous mentir ou refuse de donner sa part. Comment gérez-vous la sécurité de l'échange ?</span></label>
                <textarea id="scenarioMm" placeholder="Expliquez votre procédure de sécurité..."></textarea>
            </div>
        </div>

        <button type="submit">Envoyer ma candidature complète</button>
    </form>
</div>

<script>
    function changerPoste() {
        const poste = document.getElementById('poste').value;
        
        const sStaff = document.getElementById('sectionStaff');
        const sAnim = document.getElementById('sectionAnimateur');
        const sMm = document.getElementById('sectionMiddleman');

        // On cache tout d'abord
        sStaff.classList.add('hidden');
        sAnim.classList.add('hidden');
        sMm.classList.add('hidden');

        sStaff.classList.remove('fade-in');
        sAnim.classList.remove('fade-in');
        sMm.classList.remove('fade-in');

        // On affiche la section correspondante avec animation
        if (poste === 'Staff') { sStaff.classList.remove('hidden'); sStaff.classList.add('fade-in'); }
        if (poste === 'Animateur') { sAnim.classList.remove('hidden'); sAnim.classList.add('fade-in'); }
        if (poste === 'Middleman') { sMm.classList.remove('hidden'); sMm.classList.add('fade-in'); }
    }

    document.getElementById('recrutementForm').addEventListener('submit', function(e) {
        e.preventDefault();

        const monMail = "arm8.recrutement@gmail.com";
        const pseudo = document.getElementById('pseudo').value;
        const age = document.getElementById('age').value;
        const dispo = document.getElementById('dispo').value;
        const poste = document.getElementById('poste').value;
        
        let corpsMail = `=========================================\n`;
        corpsMail += `   NOUVELLE CANDIDATURE - ARM8 SERVER   \n`;
        corpsMail += `=========================================\n\n`;
        corpsMail += `● Pseudo Discord : ${pseudo}\n`;
        corpsMail += `● Âge : ${age} ans\n`;
        corpsMail += `● Disponibilités : ${dispo}\n`;
        corpsMail += `● Poste convoité : ${poste}\n\n`;
        corpsMail += `-----------------------------------------\n`;
        corpsMail += `          RÉPONSES AU QUESTIONNAIRE      \n`;
        corpsMail += `-----------------------------------------\n\n`;

        if (poste === 'Staff') {
            corpsMail += `[1. Expériences en Modération] :\n${document.getElementById('xpStaff').value}\n\n`;
            corpsMail += `[2. Motivations profondes] :\n${document.getElementById('motivationStaff').value}\n\n`;
            corpsMail += `[3. Scénario de crise (Spam/Insultes)] :\n${document.getElementById('scenarioStaff').value}\n`;
        } else if (poste === 'Animateur') {
            corpsMail += `[1. Idées d'animations originales] :\n${document.getElementById('ideesAnim').value}\n\n`;
            corpsMail += `[2. Expériences d'Animateur] :\n${document.getElementById('xpAnim').value}\n`;
        } else if (poste === 'Middleman') {
            corpsMail += `[1. Historique transactions / Preuves] :\n${document.getElementById('xpMm').value}\n\n`;
            corpsMail += `[2. Scénario litige / Tentative d'arnaque] :\n${document.getElementById('scenarioMm').value}\n`;
        }

        corpsMail += `\n=========================================`;

        const sujet = encodeURIComponent(`Candidature ${poste} - ${pseudo} (${age} ans)`);
        const message = encodeURIComponent(corpsMail);

        window.location.href = `mailto:${monMail}?subject=${sujet}&body=${message}`;
    });
</script>

</body>
</html>
